{
  "device_name": "observer-pi-legacy",
  "camera": {
    "source": 0,
    "width": 640,
    "height": 480,
    "fps": 15,
    "flip_horizontal": true,
    "rotate_ccw_90": false
  },
  "processing": {
    "roi": {
      "x": 60,
      "y": 90,
      "width": 520,
      "height": 250
    },
    "blur_kernel": 5,
    "morph_kernel": 5,
    "open_iterations": 1,
    "close_iterations": 2,
    "min_contour_area": 900,
    "normalize_lighting": false,
    "clahe_clip_limit": 0.0,
    "clahe_tile_grid_size": 8,
    "min_saturation": 35,
    "min_value": 35
  },
  "tracker": {
    "max_distance": 95,
    "max_missed_frames": 12,
    "min_confirmed_frames": 2,
    "max_unconfirmed_missed_frames": 2,
    "expected_direction": "left_to_right",
    "direction_slack": 20,
    "min_area_ratio": 0.5,
    "max_area_ratio": 2.0
  },
  "line_counter": {
    "enabled": true,
    "x": 320,
    "direction": "left_to_right"
  },
  "mqtt": {
    "enabled": true,
    "host": "broker.emqx.io",
    "port": 1883,
    "client_id": "mes-observer-pi-legacy",
    "topic_root": "sau/iot/mega/konveyor/vision",
    "keepalive": 60,
    "heartbeat_interval_sec": 10,
    "publish_interval_sec": 0.5,
    "qos": 0
  },
  "ui": {
    "show_windows": false,
    "show_masks": false,
    "show_pending_tracks": false,
    "preview_scale": 0.7,
    "show_overlay": true
